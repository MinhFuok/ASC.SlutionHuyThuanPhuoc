@model ASC.WebHuyThuanPhuoc.Areas.ServiceRequests.Models.DashboardViewModel

@{
    Layout = "_SecureLayout";
}

<div class="row">
    <div class="col s12">
        <div class="white" style="padding:20px; margin-top:20px;">
            @await Html.PartialAsync("_ServiceRequestGrid", Model.ServiceRequests,
                new ViewDataDictionary(ViewData)
                {
                    { "SectionName", "Service Requests" },
                    { "Id", "tblServiceRequests" },
                    { "IsAudit", false }
                })
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tblServiceRequests').DataTable({
                pageLength: 3,
                lengthMenu: [[3, 5, 10, -1], [3, 5, 10, "All"]],
                order: [],
                autoWidth: false,
                columns: [
                    { visible: false },   // RowKey
                    null,                 // User
                    null,                 // Status
                    { width: "20%" },     // Requested Date
                    null,                 // Service Engineer
                    null                  // View
                ]
            });

            $('#tblServiceRequests').css('width', '100%');

            if ($.fn.formSelect) {
                $('select[name="tblServiceRequests_length"]').formSelect();
            }
        });
    </script>
}