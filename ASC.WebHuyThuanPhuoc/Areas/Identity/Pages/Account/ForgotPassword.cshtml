@page
@model ASC.WebHuyThuanPhuoc.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="section">
        <div class="row">
            <div class="col s12 m8 offset-m2 l6 offset-l3">
                <div class="card">
                    <div class="card-content">
                        <span class="card-title">Forgot Password</span>

                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                            <div class="input-field">
                                <input asp-for="Input.Email" />
                                <label asp-for="Input.Email"></label>
                                <span asp-validation-for="Input.Email" class="red-text"></span>
                            </div>

                            <div class="section">
                                <button type="submit" class="btn waves-effect waves-light teal">
                                    Send Reset Link
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}