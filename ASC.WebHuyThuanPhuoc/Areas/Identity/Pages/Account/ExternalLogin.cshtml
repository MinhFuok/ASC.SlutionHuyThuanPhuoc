@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="section">
        <div class="row">
            <div class="col s12 m8 offset-m2 l6 offset-l3">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <p>
                    You've successfully authenticated with <strong>@Model.ProviderDisplayName</strong>.
                    Please click the Register button to finish logging in.
                </p>

                <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div class="input-field">
                        <input asp-for="Input.Email" readonly />
                        <label asp-for="Input.Email"></label>
                        <span asp-validation-for="Input.Email" class="red-text"></span>
                    </div>

                    <button type="submit" class="btn waves-effect waves-light teal">
                        Register
                        <i class="material-icons right">send</i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
