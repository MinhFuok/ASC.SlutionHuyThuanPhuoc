@page
@model ASC.WebHuyThuanPhuoc.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="section">
        <div class="row">
            <div class="col s12 m6 offset-m3 l5 offset-l1">
                <div class="card">
                    <div class="card-content">
                        <span class="card-title">Login</span>

                        <form id="account" method="post">
                            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                            <div class="input-field">
                                <input asp-for="Input.Email" />
                                <label asp-for="Input.Email"></label>
                                <span asp-validation-for="Input.Email" class="red-text"></span>
                            </div>

                            <div class="input-field">
                                <input asp-for="Input.Password" />
                                <label asp-for="Input.Password"></label>
                                <span asp-validation-for="Input.Password" class="red-text"></span>
                            </div>

                            <p>
                                <label>
                                    <input asp-for="Input.RememberMe" type="checkbox" />
                                    <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                                </label>
                            </p>

                            <div class="section">
                                <button type="submit" class="btn waves-effect waves-light teal">
                                    Log in
                                </button>
                            </div>

                            <p>
                                <a asp-page="./ForgotPassword">Forgot your password?</a>
                            </p>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col s12 m6 l5">
                <div class="card">
                    <div class="card-content">
                        <span class="card-title">Login using External Providers</span>

                        @if (Model.ExternalLogins?.Count > 0)
                        {
                            <form asp-page="./ExternalLogin"
                                  asp-route-returnUrl="@Model.ReturnUrl"
                                  method="post">
                                @foreach (var provider in Model.ExternalLogins)
                                {
                                    <button type="submit"
                                            class="btn waves-effect waves-light teal"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Log in using your @provider.DisplayName account">
                                        @provider.DisplayName
                                    </button>
                                }
                            </form>
                        }
                        else
                        {
                            <p>No external authentication providers are configured.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
